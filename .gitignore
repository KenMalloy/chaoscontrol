.venv/
.worktrees/
__pycache__/
*.pyc
*.egg-info/
*.so
build/
/results/
experiments/*/results/*
!experiments/*/results/.gitkeep
*.pt
*.bin
.claude/

# Temporary experiment configs (generated by runners)
.tmp_*
experiments/*/configs/.tmp_*
experiments/*/configs_*/

# Logs
*.log
tools/*.log

# Results directories (generated, not tracked)
experiments/*/results_*/

# Calibration artifacts (generated by exp26 stage 1+2)
experiments/*/calibration/*
!experiments/*/calibration/.gitkeep

# Profile traces (generated by profile_ssm_scan.py, large + transient)
experiments/*/profile_traces/

# Generated validation/eval caches
cache/
experiments/*/cache*/
exp20_val_cache*/

# Paper results registry — local-only run records, not versioned
paper_results/registry.jsonl

# External baseline data (tokenizers + challenge shards) — local-only, not versioned
baselines/parameter_golf/tokenizers/
baselines/parameter_golf/datasets/
baselines/parameter_golf/docs_selected*
baselines/parameter_golf/manifest.json

# OS / editor
.DS_Store
package-lock.json

# Generated controller weight artifacts (CSWG v3). Reproducible from
# experiments/25_controller_pretrain/pretrain_controller.py with a
# fixed seed; no point versioning the binary.
*.cswg

# Async communication folder for Ken-and-Claude when one is at work and
# the other is iterating. Convention is in dispatch/README.md.
/dispatch/
