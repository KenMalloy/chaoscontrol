cache/
experiments/*/cache*/
exp20_val_cache*/

# Paper results registry — local-only run records, not versioned
paper_results/registry.jsonl

# External baseline data (tokenizers + challenge shards) — local-only, not versioned
baselines/parameter_golf/tokenizers/
baselines/parameter_golf/datasets/
baselines/parameter_golf/docs_selected*
baselines/parameter_golf/manifest.json

